local savedMapProps     = {}
local mapPlatform       = nil
local mapHideConnection = nil

local IGNORED_FOLDERS = {
    ["GameObjects"] = true,
    ["Terrain"]     = true,
}

local function hidePart(obj, char)
    if not obj:IsA("BasePart") or obj.Name == "MRCPlatform" then return end
    local topParent = obj
    while topParent.Parent and topParent.Parent ~= workspace do
        topParent = topParent.Parent
    end
    local skip = IGNORED_FOLDERS[topParent.Name] or (char and obj:IsDescendantOf(char))
    if not skip and not savedMapProps[obj] then
        savedMapProps[obj] = {
            Transparency = obj.Transparency,
            CanCollide   = obj.CanCollide,
            CastShadow   = obj.CastShadow,
        }
        obj.Transparency = 1
        obj.CanCollide   = false
        obj.CastShadow   = false
    end
end

local function hideMap()
    local char = LocalPlayer.Character
    if not char then return end

    local hrp = char:FindFirstChild("HumanoidRootPart")
    if hrp then
        mapPlatform = Instance.new("Part")
        mapPlatform.Name         = "MRCPlatform"
        mapPlatform.Size         = Vector3.new(50, 1, 50)
        mapPlatform.Position     = Vector3.new(hrp.Position.X, hrp.Position.Y - 5, hrp.Position.Z)
        mapPlatform.Anchored     = true
        mapPlatform.CanCollide   = true
        mapPlatform.Transparency = 0.7
        mapPlatform.BrickColor   = BrickColor.new("Dark indigo")
        mapPlatform.Material     = Enum.Material.SmoothPlastic
        mapPlatform.CastShadow   = false
        mapPlatform.Parent       = workspace
        hrp.CFrame = CFrame.new(hrp.Position.X, mapPlatform.Position.Y + 5, hrp.Position.Z)
    end

    local descendants = workspace:GetDescendants()
    local chunkSize   = 200
    task.spawn(function()
        for i = 1, #descendants, chunkSize do
            for j = i, math.min(i + chunkSize - 1, #descendants) do
                hidePart(descendants[j], char)
            end
            task.wait()
        end
    end)

    workspace.Terrain.WaterTransparency = 1

    mapHideConnection = workspace.DescendantAdded:Connect(function(obj)
        task.wait()
        hidePart(obj, LocalPlayer.Character)
    end)
end

local function showMap()
    if mapHideConnection then
        mapHideConnection:Disconnect()
        mapHideConnection = nil
    end

    for obj, props in pairs(savedMapProps) do
        if obj and obj.Parent then
            obj.Transparency = props.Transparency
            obj.CanCollide   = props.CanCollide
            obj.CastShadow   = props.CastShadow
        end
    end
    savedMapProps = {}

    if mapPlatform then
        mapPlatform:Destroy()
        mapPlatform = nil
    end

    workspace.Terrain.WaterTransparency = 0
end

