-- AUTO HATCH
-- ================================================
local function startHatching()
    while State.hatching do
        if EggRF then
            local ok, result = pcall(function()
                return EggRF:InvokeServer("Bunny", nil, nil, true, true, true, nil)
            end)
            if ok and result then
                Stats.eggs += getHatchCount()
                updateStatLabel("eggs")
            end
        end
        task.wait(0.15 + math.random(0, 5) / 100)
    end
end

local function mutateBatch()
    if not PetRF or not MutateRF then return end
    local success, pets = pcall(function()
        return PetRF:InvokeServer(LocalPlayer)
    end)
    if not success or typeof(pets) ~= "table" then return end
    for uuid, data in pairs(pets) do
        if not State.mutating then break end
        if data and not data.Locked and not data.Cure then
            pcall(function() MutateRF:InvokeServer(uuid, {}) end)
            Stats.mutations += 1
            updateStatLabel("mutations")
            task.wait(math.random(40, 70) / 100)
        end
    end
end

local function startAutoMutate()
    while State.mutating do
        mutateBatch()
        task.wait(2)
    end
end

local function startAutoUpgrade()
    while State.upgrading do
        if UpgradeRF then
            pcall(function() UpgradeRF:InvokeServer("BunnyBurrow", "MoreCarrots") end)
            task.wait(0.2)
            pcall(function() UpgradeRF:InvokeServer("BunnyBurrow", "MoreSpawns") end)
        end
        task.wait(math.random(40, 70) / 100)
    end
end

local critTick = 0
local function startClicking()
    task.spawn(function()
        while State.clicking do
            if ClickRF then
                pcall(function() ClickRF:InvokeServer(true) end)
                Stats.clicks += 1
                updateStatLabel("clicks")
            end
            critTick += 1
            if CritRF and critTick % 5 == 0 then
                pcall(function() CritRF:InvokeServer() end)
            end
            task.wait(0.04 + math.random(0, 10) / 1000)
        end
    end)
end

local function startAutoAscend()
    while State.ascending do
        if AscendRF then
            pcall(function() AscendRF:InvokeServer("BunnyBurrow") end)
        end
        task.wait(math.random(3, 5))
    end
end

local function startAutoRune()
    while State.runing do
        if RuneRF then
            local ok, result = pcall(function()
                return RuneRF:InvokeServer("BunnyBurrow")
            end)
            if ok and result then
                Stats.runes += 1
                updateStatLabel("runes")
            end
        end
        task.wait(0.3 + math.random(10, 20) / 100)
    end
end

