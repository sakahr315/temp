MutateTab:CreateToggle({
    Name = "Auto Mutate All Pets",
    Callback = function(v)
        if v and not checkRemotes("Auto Mutate") then return end
        State.mutating = v
        if v then task.spawn(startAutoMutate) end
    end
})
